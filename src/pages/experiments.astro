---
import BaseLayout from "../layouts/BaseLayout.astro";
import QuoteMachine from "../components/QuoteMachine";
import WeatherDashboard from "../components/WeatherDashboard";
---

<BaseLayout
	title="Web Development Experiments"
	description="Interactive experiments with Astro islands and modern web dev."
>
	<main>
		<h1>🧪 Experiments</h1>

		<div class="past-experiment">
			<p><strong>Past experiment:</strong> Live Visitor Counter — a real-time visitor tracker built with Supabase and Astro islands. Retired after the Supabase free tier project was suspended.</p>
		</div>

		<QuoteMachine client:idle />

		<WeatherDashboard client:load />
	</main>
</BaseLayout>

<style>
.past-experiment {
	background: #f3f4f6;
	border-left: 4px solid #9ca3af;
	padding: 1rem 1.25rem;
	border-radius: 0 8px 8px 0;
	margin-bottom: 2rem;
	color: #4b5563;
}

.past-experiment p {
	margin: 0;
}
</style>